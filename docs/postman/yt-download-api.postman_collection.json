{
  "info": {
    "name": "YT Download API",
    "_postman_id": "d96816dc-84e5-4a56-8f3c-yt-download-api",
    "description": "Postman collection for the YT Download API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "managementSecret",
      "value": "change-me-in-production"
    }
  ],
  "item": [
    {
      "name": "Healthcheck",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Checks whether the API is available."
      },
      "response": []
    },
    {
      "name": "Download Video",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"https://www.youtube.com/watch?v=jNQXAC9IVRw\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/downloads",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "downloads"
          ]
        },
        "description": "Starts the video download and returns the binary file."
      },
      "response": []
    },
    {
      "name": "List Access Tokens",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{managementSecret}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/access-tokens",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "access-tokens"
          ]
        },
        "description": "Lists all stored access tokens for the management console."
      },
      "response": []
    },
    {
      "name": "Create Access Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{managementSecret}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Internal client\",\n  \"description\": \"Main integration token\",\n  \"content\": \"super-secret-token-value\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/access-tokens",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "access-tokens"
          ]
        },
        "description": "Creates a new encrypted access token record."
      },
      "response": []
    }
  ]
}
